overround_1x2 <- prob_H + prob_D + prob_A
prob_O25 <- 1 / odds_O25
prob_U25 <- 1 / odds_U25
overround_OU <- prob_O25 + prob_U25
prob_BTTS_Y <- 1 / odds_BTTS_Y
prob_BTTS_N <- 1 / odds_BTTS_N
overround_BTTS <- prob_BTTS_Y + prob_BTTS_N
# Tiszta ("valós") valószínűségek a vig eltávolításával
true_prob_H <- prob_H / overround_1x2
true_prob_D <- prob_D / overround_1x2
true_prob_A <- prob_A / overround_1x2
true_prob_O25 <- prob_O25 / overround_OU
true_prob_BTTS_Y <- prob_BTTS_Y / overround_BTTS
# Cél valószínűségek egy vektorban, amit az optimalizáló használni fog
target_probs <- c(H = true_prob_H,
D = true_prob_D,
A = true_prob_A,
O25 = true_prob_O25,
BTTS_Y = true_prob_BTTS_Y)
calculate_error <- function(params) {
lambda_h <- params[1]
lambda_v <- params[2]
# Maximális gólszám, amit a modell figyelembe vesz (10 elég)
max_goals <- 10
# Pontos eredmény mátrix létrehozása
# A mátrix[i,j] eleme az (i-1) - (j-1) eredmény valószínűsége
score_matrix <- dpois(0:max_goals, lambda_h) %o% dpois(0:max_goals, lambda_v)
# A piaci valószínűségek kiszámítása a Poisson-modellből
model_prob_H <- sum(score_matrix[lower.tri(score_matrix)])
model_prob_D <- sum(diag(score_matrix))
model_prob_A <- sum(score_matrix[upper.tri(score_matrix)])
# Under 2.5 valószínűsége: P(0-0, 1-0, 0-1, 1-1, 2-0, 0-2)
prob_under_25 <- score_matrix[1,1] + score_matrix[2,1] + score_matrix[1,2] + score_matrix[2,2] + score_matrix[3,1] + score_matrix[1,3]
model_prob_O25 <- 1 - prob_under_25
# BTTS - Nem valószínűsége: ha a hazai VAGY a vendég 0 gólt szerez
prob_btts_no <- sum(score_matrix[1,]) + sum(score_matrix[,1]) - score_matrix[1,1]
model_prob_BTTS_Y <- 1 - prob_btts_no
# Modell valószínűségek egy vektorban
model_probs <- c(H = model_prob_H,
D = model_prob_D,
A = model_prob_A,
O25 = model_prob_O25,
BTTS_Y = model_prob_BTTS_Y)
# A négyzetes hiba kiszámítása és összegzése
# Ez az az érték, amit minimalizálni szeretnénk
error <- sum((model_probs - target_probs)^2)
return(error)
}
# --------------------------------------------------------------------------
# 4. LÉPÉS: AZ OPTIMALIZÁCIÓ FUTTATÁSA
# --------------------------------------------------------------------------
# Kezdőértékek a várható gólokra (az optim() innen indul a kereséssel)
initial_guess <- c(1.5, 1.2)
# Az optim() függvény futtatása, ami megkeresi a legjobb lambda_h és lambda_v értékeket
# 'L-BFGS-B' metódust használunk, ami lehetővé teszi alsó korlátok megadását,
# így biztosítva, hogy a várható gólok ne legyenek negatívak.
result <- optim(par = initial_guess,
fn = calculate_error,
method = "L-BFGS-B",
lower = c(0.01, 0.01))
# --------------------------------------------------------------------------
# 5. LÉPÉS: EREDMÉNYEK MEGJELENÍTÉSE
# --------------------------------------------------------------------------
if (result$convergence == 0) {
cat("#############################################\n")
cat("## EREDMÉNYEK\n")
cat("#############################################\n\n")
lambda_home_final <- result$par[1]
lambda_away_final <- result$par[2]
cat(sprintf("A modell által becsült várható gólok:\n"))
cat(sprintf("   - Hazai csapat (λ H): %.2f gól\n", lambda_home_final))
cat(sprintf("   - Vendég csapat (λ V): %.2f gól\n\n", lambda_away_final))
cat(sprintf("A meccs összesített várható góljainak száma: %.2f gól\n", lambda_home_final + lambda_away_final))
} else {
cat("Az optimalizáció nem volt sikeres. Próbálj meg más kezdőértékeket vagy ellenőrizd az oddsokat.\n")
cat("Konvergencia kód:", result$convergence, "\n")
}
# --------------------------------------------------------------------------
# 1. LÉPÉS: ADD MEG AZ ODDSOKAT MANUÁLISAN
# --------------------------------------------------------------------------
## INPUT ##
# Cseréld le az alábbi értékeket a konkrét mérkőzés oddsaival!
odds_H      <- 4.50  # Hazai győzelem (1)
odds_D      <- 4.15  # Döntetlen (X)
odds_A      <- 1.70  # Vendég győzelem (2)
odds_O25    <- 1.52  # Gólszám 2.5 Felett (Over)
odds_U25    <- 2.40  # Gólszám 2.5 Alatt (Under)
odds_BTTS_Y <- 1.54  # Mindkét csapat szerez gólt - Igen (Yes)
odds_BTTS_N <- 2.35  # Mindkét csapat szerez gólt - Nem (No)
# --------------------------------------------------------------------------
# 2. LÉPÉS: VALÓSZÍNŰSÉGEK KISZÁMÍTÁSA ÉS A BUKMÉKER HASZNÁNAK (VIG) ELTÁVOLÍTÁSA
