library(RSQLite)
library(dplyr)
library(tidyr)
library(DT)
library(plotly)
con <- dbConnect(RSQLite::SQLite(), "/Users/kaszailevente/Library/Mobile Documents/com~apple~CloudDocs/Kosárlabda/bball_10_tables.db")
off_stats <- dbGetQuery(con, "SELECT CAST(Season AS INTEGER) as Season, Csapat, `Gy%` as Win_Pct, `EFG%` as Off_eFG, `TOV%` as Off_TOV, `ORB%` as Off_ORB, `FT rate` as Off_FTR FROM team_stats")
def_stats  <- dbGetQuery(con, "SELECT CAST(Season AS INTEGER) as Season, Csapat, `EFG%` as Def_eFG, `TOV%` as Def_TOV, `DRB%` as Def_DRB, `FT att. rate` as Def_FTR FROM opponent_stats")
dbDisconnect(con)
ff_data <- off_stats %>%
inner_join(def_stats, by = c("Season", "Csapat")) %>%
mutate(
Szezon  = paste0("20", substr(as.character(Season), 1, 2), "-", substr(as.character(Season), 3, 4)),
Net_eFG = Off_eFG - Def_eFG,
Net_TOV = Def_TOV - Off_TOV,
Net_FTR = Off_FTR - Def_FTR
# Net_ORB törölve — matematikailag mindig 0
)
cor(ff_data %>% select(Win_Pct, Net_eFG, Net_TOV, Off_ORB, Def_DRB, Net_FTR),
use = "complete.obs") %>%
round(3)
library(DBI)
library(RSQLite)
library(dplyr)
library(tidyr)
library(DT)
library(plotly)
con <- dbConnect(RSQLite::SQLite(), "/Users/kaszailevente/Library/Mobile Documents/com~apple~CloudDocs/Kosárlabda/bball_10_tables.db")
off_stats <- dbGetQuery(con, "SELECT CAST(Season AS INTEGER) as Season, Csapat,
`Gy%` as Win_Pct,
`EFG%` as Off_eFG,
`TOV%` as Off_TOV,
`ORB%` as Off_ORB,
`DRB%` as Def_DRB,
`FT rate` as Off_FTR
FROM team_stats")
def_stats  <- dbGetQuery(con, "SELECT CAST(Season AS INTEGER) as Season, Csapat,
`EFG%` as Def_eFG,
`TOV%` as Def_TOV,
`FT att. rate` as Def_FTR
FROM opponent_stats")
dbDisconnect(con)
ff_data <- off_stats %>%
inner_join(def_stats, by = c("Season", "Csapat")) %>%
mutate(
Szezon  = paste0("20", substr(as.character(Season), 1, 2), "-", substr(as.character(Season), 3, 4)),
Net_eFG = Off_eFG - Def_eFG,
Net_TOV = Def_TOV - Off_TOV,
Net_FTR = Off_FTR - Def_FTR
)
cor(ff_data %>% select(Win_Pct, Net_eFG, Net_TOV, Off_ORB, Def_DRB, Net_FTR),
use = "complete.obs") %>%
round(3)
cor(ff_data %>% select(Win_Pct, Off_eFG, Def_eFG, Off_TOV, Def_TOV, Off_ORB, Def_DRB, Off_FTR, Def_FTR),
use = "complete.obs") %>%
round(3)
ff_data %>%
select(Csapat, Szezon, Win_Pct, Off_eFG, Def_eFG, Off_ORB, Def_DRB, Off_TOV, Def_TOV, Off_FTR, Def_FTR) %>%
arrange(desc(Win_Pct)) %>%
head(10)
# Futtasd le, írd ide az eredményt
ff_data %>%
mutate(across(c(Net_eFG, Off_ORB, Def_DRB, Net_TOV, Net_FTR),
~ as.numeric(scale(.)), .names = "z_{.col}")) %>%
summarise(across(starts_with("z_"),
list(n_outlier = ~ sum(abs(.) > 1.5, na.rm = TRUE))))
