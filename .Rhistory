library(DBI)
library(RSQLite)
con <- dbConnect(RSQLite::SQLite(), "/Users/kaszailevente/Library/Mobile Documents/com~apple~CloudDocs/Kosárlabda/bball_10_tables.db")
# 1. Átmeneti tábla létrehozása helyes típussal
dbExecute(con, "CREATE TABLE opponent_stats_new AS SELECT CAST(Season AS INTEGER) as Season, * FROM opponent_stats")
# 2. Régi Season oszlop eltávolítása (SQLite-ban ez újraépítéssel megy)
dbExecute(con, "CREATE TABLE opponent_stats_fixed AS SELECT CAST(Season AS INTEGER) as Season, Csapat, * FROM opponent_stats")
# Egyszerűbb megoldás: felülírjuk az egész táblát
opponent_data <- dbGetQuery(con, "SELECT * FROM opponent_stats")
opponent_data$Season <- as.integer(opponent_data$Season)
dbExecute(con, "DROP TABLE opponent_stats")
dbWriteTable(con, "opponent_stats", opponent_data)
# Ellenőrzés
print(dbGetQuery(con, "SELECT typeof(Season) FROM team_stats LIMIT 1"))
print(dbGetQuery(con, "SELECT typeof(Season) FROM opponent_stats LIMIT 1"))
dbDisconnect(con)
glimpse(ff_data)
library(DBI)
library(RSQLite)
library(dplyr)
library(tidyr)
library(DT)
library(plotly)
con <- dbConnect(RSQLite::SQLite(), "/Users/kaszailevente/Library/Mobile Documents/com~apple~CloudDocs/Kosárlabda/bball_10_tables.db")
off_stats <- dbGetQuery(con, "SELECT CAST(Season AS INTEGER) as Season, Csapat, `Gy%` as Win_Pct, `EFG%` as Off_eFG, `TOV%` as Off_TOV, `ORB%` as Off_ORB, `FT rate` as Off_FTR FROM team_stats")
def_stats  <- dbGetQuery(con, "SELECT CAST(Season AS INTEGER) as Season, Csapat, `EFG%` as Def_eFG, `TOV%` as Def_TOV, `DRB%` as Def_DRB, `FT att. rate` as Def_FTR FROM opponent_stats")
dbDisconnect(con)
ff_data <- off_stats %>%
inner_join(def_stats, by = c("Season", "Csapat")) %>%
mutate(
Szezon  = paste0("20", substr(as.character(Season), 1, 2), "-", substr(as.character(Season), 3, 4)),
Net_eFG = Off_eFG - Def_eFG,
Net_TOV = Def_TOV - Off_TOV,
Net_ORB = Off_ORB - (100 - Def_DRB),
Net_FTR = Off_FTR - Def_FTR
)
glimpse(ff_data)
summary(ff_data %>% select(Win_Pct, Net_eFG, Net_TOV, Net_ORB, Net_FTR))
